<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Decision_Maker.SupabasePage"
             Title="SupabasePage"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*,Auto"
          Padding="30"
          RowSpacing="20">

        <!-- GetUsers nupp -->
        <Button Grid.Row="0"
                Text="GetUsers"
                Clicked="OnTestClicked"
                HeightRequest="55"
                WidthRequest="200"
                CornerRadius="27"
                BackgroundColor="#D9D9D9"
                TextColor="Black"
                HorizontalOptions="Center"/>

        <!-- Scrollitav kast -->
        <CollectionView Grid.Row="1"
                        x:Name="UsersList"
                        BackgroundColor="#EEEEEE">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*,Auto" Padding="5" Margin="5" BackgroundColor="White">
                        <Label Text="{Binding Name}" FontSize="18" VerticalOptions="Center" />
                        <Button Text="Delete"
                                Grid.Column="1"
                                BackgroundColor="#FF6B6B"
                                TextColor="White"
                                CornerRadius="10"
                                Clicked="OnDeleteClicked"
                                CommandParameter="{Binding Id}"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <!-- Lisa uus kasutaja nupp -->
        <Button Grid.Row="2"
                Text="Add User"
                Clicked="OnAddUserClicked"
                HeightRequest="55"
                WidthRequest="200"
                CornerRadius="27"
                BackgroundColor="#4CAF50"
                TextColor="White"
                HorizontalOptions="Center"/>
    </Grid>
</ContentPage>