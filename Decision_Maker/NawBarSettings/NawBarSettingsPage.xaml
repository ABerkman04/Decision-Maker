<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Decision_Maker.NawBarSettings.NawBarSettingsPage"
             xmlns:components="clr-namespace:Decision_Maker.Components"
             xmlns:strings="clr-namespace:Decision_Maker.Resources.Localization"
             BackgroundColor="Gray"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="*,80"
          RowSpacing="0">

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="0">

            <!-- background -->
            <Border BackgroundColor="#C4F1C0"
                    StrokeThickness="0" />

            <!-- pattern -->
            <Image Source="pattern.png"
                   Aspect="AspectFill"/>

            <!-- content layout -->
            <Grid Padding="20,30,20,20"
                  RowDefinitions="Auto,*">

                <!-- HEADER -->
                <HorizontalStackLayout Grid.Row="0"
                                       Spacing="12">

                    <Image Source="icon1.png"
                           WidthRequest="34"
                           HeightRequest="34"
                           Aspect="AspectFit" />

                    <Label Text="{x:Static strings:AppResources.Decision_Maker}"
                           FontSize="20"
                           FontFamily="AlegreyaSansExtraBold"
                           VerticalOptions="Center"
                           TextColor="Black" />
                </HorizontalStackLayout>

                <!-- CENTER AREA -->
                <Grid Grid.Row="1">

                    <Border BackgroundColor="#FFFFFF"
                            Stroke="#D9D9D9"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16"
                            Padding="20,22,20,40"
                            HorizontalOptions="Fill"
                            VerticalOptions="Center"
                            Margin="0,-150,0,130">

                        <Border.Shadow>
                            <Shadow Brush="#000000"
                                    Offset="0,1"
                                    Radius="4"
                                    Opacity="0.40" />
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="14">

                            <!-- Header -->
                            <VerticalStackLayout Spacing="4"
                                                 Margin="0,0,0,6">
                                <Label Text="{x:Static strings:AppResources.Settings}"
                                       FontSize="20"
                                       FontFamily="AlegreyaSansExtraBold"
                                       TextColor="Black"
                                       HorizontalOptions="Center" />

                                <Label x:Name="EmailLabel"
                                       Text="username@mail.com"
                                       FontSize="14"
                                       FontFamily="AlegreyaSansRegular"
                                       TextColor="Gray"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>

                            <!-- About -->
                            <Grid ColumnDefinitions="40,*,20"
                                  Padding="0,8">
                                <Image Source="info1.png"
                                       WidthRequest="20"
                                       HeightRequest="20"
                                       VerticalOptions="Center" />

                                <Label Grid.Column="1"
                                       Margin="6,0,0,0"
                                       Text="{x:Static strings:AppResources.About_app}"
                                       FontSize="16"
                                       FontFamily="AlegreyaSansRegular"
                                       TextColor="Black"
                                       VerticalOptions="Center" />

                                <Image Grid.Column="2"
                                       Source="arrow1.png"
                                       WidthRequest="8"
                                       Margin="0,0,15,0"
                                       VerticalOptions="Center"
                                       HorizontalOptions="End" />

                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="AboutClicked"/>
                                </Grid.GestureRecognizers>
                            </Grid>

                            <BoxView HeightRequest="1"
                                     Color="#E5E5E5" />

                            <!-- Language -->
                            <Grid ColumnDefinitions="40,*,20"
                                  Padding="0,8">
                                <Image Source="language1.png"
                                       WidthRequest="20"
                                       HeightRequest="20"
                                       VerticalOptions="Center" />

                                <Label Grid.Column="1"
                                       Margin="6,0,0,0"
                                       Text="{x:Static strings:AppResources.Language}"
                                       FontSize="16"
                                       FontFamily="AlegreyaSansRegular"
                                       TextColor="Black"
                                       VerticalOptions="Center" />

                                <Image Grid.Column="2"
                                       Source="arrow1.png"
                                       WidthRequest="8"
                                       Margin="0,0,15,0"
                                       VerticalOptions="Center"
                                       HorizontalOptions="End" />

                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="LanguageClicked"/>
                                </Grid.GestureRecognizers>
                            </Grid>

                            <BoxView HeightRequest="1"
                                     Color="#E5E5E5" />

                            <!-- Logout -->
                            <Grid ColumnDefinitions="40,*,20"
                                  Padding="0,8">
                                <Image Source="logout1.png"
                                       WidthRequest="20"
                                       HeightRequest="20"
                                       VerticalOptions="Center" />

                                <Label Grid.Column="1"
                                       Margin="6,0,0,0"
                                       Text="{x:Static strings:AppResources.Log_out}"
                                       FontSize="16"
                                       FontFamily="AlegreyaSansRegular"
                                       TextColor="Red"
                                       VerticalOptions="Center" />

                                <Image Grid.Column="2"
                                       Source="arrow1.png"
                                       WidthRequest="8"
                                       Margin="0,0,15,0"
                                       VerticalOptions="Center"
                                       HorizontalOptions="End" />

                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="LogoutClicked"/>
                                </Grid.GestureRecognizers>
                            </Grid>

                            <BoxView HeightRequest="1"
                                     Color="#E5E5E5" />

                        </VerticalStackLayout>


        <!-- LANGUAGE OVERLAY -->
        <Grid x:Name="LanguageOverlay"
              IsVisible="False"
              BackgroundColor="#80000000">
            <!-- poolläbipaistev taust -->

            <!-- White panel -->
            <Frame
                BackgroundColor="White"
                CornerRadius="20"
                Padding="20"
                Margin="40,120,40,120"
                VerticalOptions="Center">

                <VerticalStackLayout Spacing="20">

                    <!-- Header -->
                    <Grid ColumnDefinitions="*,Auto">

                        <Label Text="{x:Static strings:AppResources.Language}"
                       FontSize="20"
                       FontAttributes="Bold"
                       VerticalOptions="Center"/>

                        <!-- Close X -->
                        <Label Grid.Column="1"
                       Text="✕"
                       FontSize="20"
                       VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="CloseLanguageOverlay"/>
                            </Label.GestureRecognizers>
                        </Label>

                    </Grid>

                    <!-- English -->
                    <Label Text="English" 
                   FontSize="16">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="EnglishClicked"/>
                        </Label.GestureRecognizers>
                    </Label>

                    <!-- Eesti -->
                    <Label Text="Eesti"
                   FontSize="16">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="EstonianClicked"/>
                        </Label.GestureRecognizers>
                    </Label>

                </VerticalStackLayout>
            </Frame>
        </Grid>

        <!-- Bottom Navbar -->
        <components:NavigationBar x:Name="NavigationBar" Grid.Row="1"/>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

    </Grid>

</ContentPage>