<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Decision_Maker.NawBarSettings.NawBarSettingsPage"
             xmlns:components="clr-namespace:Decision_Maker.Components"
             NavigationPage.HasNavigationBar="False">


    <Grid RowDefinitions="*,90">

        <!-- Background -->
        <Grid Grid.Row="0">

            <!-- Background image -->
            <Image
                Source="background.png"
                Aspect="AspectFill"/>

            <!-- Gradient overlay -->
            <BoxView Opacity="0.7">
                <BoxView.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#CFF5CF" Offset="0"/>
                        <GradientStop Color="#A8E6A1" Offset="1"/>
                    </LinearGradientBrush>
                </BoxView.Background>
            </BoxView>

            <!-- APP TITLE -->
            <HorizontalStackLayout
                Margin="20,40,0,0"
                Spacing="8"
                VerticalOptions="Start"
                HorizontalOptions="Start">

                <Image
                    Source="info1.png"
                    WidthRequest="26"
                    HeightRequest="26"/>

                <Label
                    Text="Decision Maker"
                    FontSize="20"
                    FontAttributes="Bold"
                    VerticalOptions="Center"/>

            </HorizontalStackLayout>


            <!-- Main Card -->
            <Frame
                BackgroundColor="White"
                CornerRadius="20"
                Padding="20"
                Margin="20,80,20,200"
                HasShadow="True">

                <VerticalStackLayout Spacing="10">

                    <!-- Header -->
                    <Grid ColumnDefinitions="0,*">

                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">

                            <Label
                                Text="Settings"
                                FontSize="22"
                                TextColor="Black"
                                FontAttributes="Bold"
                                HorizontalOptions="Center"/>

                            <Label
                                x:Name="EmailLabel"
                                Text="username@mail.com"
                                FontSize="12"
                                TextColor="Gray"
                                HorizontalOptions="Center"/>

                        </VerticalStackLayout>

                    </Grid>


                    <!-- About Button (replaced Button.Content with Frame + TapGestureRecognizer) -->
                    <Frame BackgroundColor="Transparent" Padding="0" HasShadow="False">
                        <Grid ColumnDefinitions="40,*,30">
                            <Image Source="info1.png" WidthRequest="25"/>
                            <Label Grid.Column="1"
                                   Margin="3,6,0,0"
                                   Text="About app"
                                   VerticalOptions="Center"/>
                            <Image Grid.Column="2"
                                   Margin="-10,13,0,0"
                                   Source="arrow1.png"
                                   WidthRequest="10"/>
                        </Grid>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="AboutClicked" NumberOfTapsRequired="1"/>
                        </Frame.GestureRecognizers>
                    </Frame>

                    <BoxView HeightRequest="1" Color="#E5E5E5"/>


                    <!-- Language Button -->
                    <Frame BackgroundColor="Transparent" Padding="0" HasShadow="False">
                        <Grid ColumnDefinitions="40,*,30">
                            <Image Source="language1.png" WidthRequest="25"/>
                            <Label Grid.Column="1"
                                   Margin="3,6,0,0"
                                   Text="Language"
                                   VerticalOptions="Center"/>
                            <Image Grid.Column="2"
                                   Margin="-10,13,0,0"
                                   Source="arrow1.png"
                                   WidthRequest="10"/>
                        </Grid>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="LanguageClicked" NumberOfTapsRequired="1"/>
                        </Frame.GestureRecognizers>
                    </Frame>

                    <BoxView HeightRequest="1" Color="#E5E5E5"/>


                    <!-- Logout Button -->
                    <Frame BackgroundColor="Transparent" Padding="0" HasShadow="False">
                        <Grid ColumnDefinitions="40,*,30">
                            <Image Source="logout1.png" WidthRequest="25"/>
                            <Label Grid.Column="1"
                                   Margin="3,6,0,0"
                                   Text="Log out"
                                   TextColor="Red"
                                   VerticalOptions="Center"/>
                            <Image Grid.Column="2"
                                   Margin="-10,13,0,0"
                                   Source="arrow1.png"
                                   WidthRequest="10"/>
                        </Grid>
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="LogoutClicked" NumberOfTapsRequired="1"/>
                        </Frame.GestureRecognizers>
                    </Frame>

                    <BoxView HeightRequest="1" Color="#E5E5E5"/>

                </VerticalStackLayout>

            </Frame>

        </Grid>


        <!-- LANGUAGE OVERLAY -->
        <Grid x:Name="LanguageOverlay"
              IsVisible="False"
              BackgroundColor="#80000000">
            <!-- poolläbipaistev taust -->

            <!-- White panel -->
            <Frame
                BackgroundColor="White"
                CornerRadius="20"
                Padding="20"
                Margin="40,120,40,120"
                VerticalOptions="Center">

                <VerticalStackLayout Spacing="20">

                    <!-- Header -->
                    <Grid ColumnDefinitions="*,Auto">

                        <Label Text="Language"
                       FontSize="20"
                       FontAttributes="Bold"
                       VerticalOptions="Center"/>

                        <!-- Close X -->
                        <Label Grid.Column="1"
                       Text="✕"
                       FontSize="20"
                       VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="CloseLanguageOverlay"/>
                            </Label.GestureRecognizers>
                        </Label>

                    </Grid>

                    <!-- English -->
                    <Label Text="English"
                   FontSize="16">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="EnglishClicked"/>
                        </Label.GestureRecognizers>
                    </Label>

                    <!-- Eesti -->
                    <Label Text="Eesti"
                   FontSize="16">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="EstonianClicked"/>
                        </Label.GestureRecognizers>
                    </Label>

                </VerticalStackLayout>
            </Frame>
        </Grid>

        <!-- Bottom Navbar -->
        <components:NavigationBar x:Name="NavigationBar" Grid.Row="1"/>

    </Grid>

</ContentPage>