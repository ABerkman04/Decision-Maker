<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Decision_Maker.AHP.CriteriaPage"
             xmlns:components="clr-namespace:Decision_Maker.Components"
             BackgroundColor="Gray"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="*,80"
          RowSpacing="0">

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="0">

            <!-- background -->
            <Border BackgroundColor="#C4F1C0"
                    StrokeThickness="0" />

            <!-- pattern -->
            <Image Source="pattern.png"
                   Aspect="AspectFill"/>

            <!-- content layout -->
            <Grid Padding="20,30,20,-20"
                  RowDefinitions="Auto,*">

                <!-- HEADER -->
                <HorizontalStackLayout Grid.Row="0"
                                       Spacing="12">

                    <Image Source="icon1.png"
                           WidthRequest="34"
                           HeightRequest="34"
                           Aspect="AspectFit" />

                    <Label Text="Decision Maker"
                           FontSize="20"
                           FontFamily="AlegreyaSansExtraBold"
                           VerticalOptions="Center"
                           TextColor="Black" />
                </HorizontalStackLayout>

                <!-- CENTER AREA -->
                <Grid Grid.Row="1">

                    <Border BackgroundColor="#F4F4F4"
                            Stroke="#D9D9D9"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16"
                            Padding="20,22"
                            HorizontalOptions="Fill"
                            VerticalOptions="Center"
                            Margin="0,-30,0,0">

                        <Border.Shadow>
                            <Shadow
                                Brush="#000000"
                                Offset="0,1"
                                Radius="4"
                                Opacity="0.40" />
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="16">

                            <Label Text="Add Criteria"
                                   FontSize="20"
                                   FontFamily="AlegreyaSansExtraBold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="Black" />

                            <Label Text="Add up to 5 criteria"
                                   FontSize="16"
                                   FontFamily="AlegreyaSansRegular"
                                   HorizontalTextAlignment="Center"
                                   TextColor="Black" />

                            <CollectionView x:Name="CriteriaList"
                                SelectionMode="None"
                                Margin="0,0,0,6">

                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border BackgroundColor="#F4F4F4"
                                            Stroke="#A8DAB0"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 16"
                                            Padding="16,0"
                                            WidthRequest="320"
                                            HeightRequest="48"
                                            Margin="0,0,0,5">

                                            <Grid ColumnDefinitions="*,Auto">

                                                <Label Text="{Binding Name}"
                                                   VerticalOptions="Center"
                                                   TextColor="Black"
                                                   FontFamily="AlegreyaSansRegular"
                                                   FontSize="16" />

                                                <Image Grid.Column="1"
                                                       Source="trash.png"
                                                       HeightRequest="22"
                                                       WidthRequest="22"
                                                       Aspect="AspectFit"
                                                       HorizontalOptions="End"
                                                       VerticalOptions="Center">
                                                    <Image.GestureRecognizers>
                                                        <TapGestureRecognizer Tapped="DeleteCriteriaClicked"
                                                                              CommandParameter="{Binding .}" />
                                                    </Image.GestureRecognizers>
                                                </Image>

                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>

                            </CollectionView>

                            <components:InputField x:Name="CriteriaEntry"
                                                   PlaceholderText="Example: Price" 
                                                   Margin="0,-30,0,20"/>

                            <components:SecondaryButton ButtonText="Add Criterion"
                                                Clicked="AddCriteriaClicked"
                                                HorizontalOptions="Center" />


                            <components:PrimaryButton ButtonText="Continue"
                                                      Clicked="ContinueClicked"
                                                      HorizontalOptions="Center"
                                                      Margin="0,0,0,5" />

                        </VerticalStackLayout>
                    </Border>

                </Grid>

            </Grid>

        </Grid>

        <!-- BOTTOM NAVBAR -->
        <components:NavigationBar x:Name="NavigationBar"
                                  Grid.Row="1" />

    </Grid>


