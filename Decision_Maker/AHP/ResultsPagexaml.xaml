<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:Decision_Maker.Components"
             x:Class="Decision_Maker.AHP.ResultsPagexaml"
             BackgroundColor="#F2F2F2">

    <Grid RowDefinitions="*,90">

        <Frame Grid.Row="0" HasShadow="False">

            <VerticalStackLayout Padding="30" Spacing="20">

                <Label Text="Results"
                       FontSize="26"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>

                <Label x:Name="DecisionNameLabel"
               FontSize="14"
               HorizontalOptions="Center"/>

                <CollectionView x:Name="ResultsList">

                    <CollectionView.ItemTemplate>

                        <DataTemplate>

                            <Frame Padding="12"
                                   BackgroundColor="#E5E5E5"
                                   CornerRadius="15"
                                   HasShadow="False">

                                <Grid ColumnDefinitions="*,Auto">

                                    <Label Text="{Binding Option}"
                                           FontSize="16"
                                           VerticalOptions="Center"/>

                                    <Label Grid.Column="1"
                                           Text="{Binding Score}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center"/>

                                </Grid>

                            </Frame>

                        </DataTemplate>

                    </CollectionView.ItemTemplate>

                </CollectionView>

            </VerticalStackLayout>

        </Frame>

        <components:NavigationBar Grid.Row="1"/>

    </Grid>

</ContentPage>