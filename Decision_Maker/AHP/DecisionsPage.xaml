<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Decision_Maker.AHP.DecisionsPage"
             xmlns:components="clr-namespace:Decision_Maker.Components"
             BackgroundColor="Gray"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="*,80"
          RowSpacing="0">

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="0">

            <!-- background -->
            <Border BackgroundColor="#C4F1C0"
                    StrokeThickness="0" />

            <!-- pattern -->
            <Image Source="pattern.png"
                   Aspect="AspectFill"/>

            <!-- content layout -->
            <Grid Padding="18,20,18,20"
                  RowDefinitions="Auto,*">

                <!-- HEADER -->
                <HorizontalStackLayout Grid.Row="0"
                                       Spacing="12">

                    <Image Source="icon1.png"
                           WidthRequest="34"
                           HeightRequest="34"
                           Aspect="AspectFit" />

                    <Label Text="Decision Maker"
                           FontSize="20"
                           FontFamily="AlegreyaSansExtraBold"
                           VerticalOptions="Center"
                           TextColor="Black" />
                </HorizontalStackLayout>

                <!-- CENTER AREA -->
                <Grid Grid.Row="1">

                    <Border BackgroundColor="#F4F4F4"
                            Stroke="#D9D9D9"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 18"
                            Padding="20,22"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            Margin="0,-20,0,0">

                        <Border.Shadow>
                            <Shadow
                                Brush="#000000"
                                Offset="0,1"
                                Radius="4"
                                Opacity="0.40" />
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="16">

                            <Label Text="Welcome, User!"
                                   FontSize="20"
                                   FontFamily="AlegreyaSansExtraBold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="Black" />

                            <Label Text="Create a decision, add options and criteria, then compare them step by step. Get a clear winner and see why it ranked highest."
                                   FontSize="14"
                                   HorizontalTextAlignment="Center"
                                   LineBreakMode="WordWrap"
                                   TextColor="Black" />

                            <components:PrimaryButton ButtonText="New decision"
                                                      Clicked="CreateDecisionClicked"
                                                      HorizontalOptions="Center"
                                                      Margin="0,4,0,0" />

                        </VerticalStackLayout>
                    </Border>

                </Grid>

            </Grid>

        </Grid>

        <!-- BOTTOM NAVBAR -->
        <components:NavigationBar x:Name="NavigationBar"
                                  Grid.Row="1" />

    </Grid>

</ContentPage>