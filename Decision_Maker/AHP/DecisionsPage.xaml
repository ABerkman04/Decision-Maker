<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Decision_Maker.AHP.DecisionsPage"
             xmlns:components="clr-namespace:Decision_Maker.Components"
             xmlns:strings="clr-namespace:Decision_Maker.Resources.Localization"
             BackgroundColor="Gray"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="*,80"
          RowSpacing="0">

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="0">

            <!-- background -->
            <Border BackgroundColor="#C4F1C0"
                    StrokeThickness="0" />

            <!-- pattern -->
            <Image Source="pattern.png"
                   Aspect="AspectFill"/>

            <!-- content layout -->
            <Grid Padding="20,30,20,20"
                  RowDefinitions="Auto,*">

                <!-- HEADER -->
                <HorizontalStackLayout Grid.Row="0"
                                       Spacing="12">

                    <Image Source="icon1.png"
                           WidthRequest="34"
                           HeightRequest="34"
                           Aspect="AspectFit" />

                    <Label Text="{x:Static strings:AppResources.Decision_Maker}"
                           FontSize="20"
                           FontFamily="AlegreyaSansExtraBold"
                           VerticalOptions="Center"
                           TextColor="Black" />
                </HorizontalStackLayout>

                <!-- CENTER AREA -->
                <Grid Grid.Row="1">

                    <Border BackgroundColor="#FFFFFF"
                            Stroke="#D9D9D9"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16"
                            Padding="20,22"
                            HorizontalOptions="Fill"
                            VerticalOptions="Center"
                            Margin="0,-80,0,0">

                        <Border.Shadow>
                            <Shadow
                                Brush="#000000"
                                Offset="0,1"
                                Radius="4"
                                Opacity="0.40" />
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="16">

                            <Label 
                                   x:Name="DisplayLabel"
                                   Text="{x:Static strings:AppResources.Welcome}"
                                   FontSize="20"
                                   FontFamily="AlegreyaSansExtraBold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="Black" />

                            <Label Text="{x:Static strings:AppResources.Create_a_decision_add_options_and_criteria}"
                                   FontSize="16"
                                   FontFamily="AlegreyaSansRegular"
                                   HorizontalTextAlignment="Center"
                                   LineBreakMode="WordWrap"
                                   LineHeight="1.3"
                                   TextColor="Black" />

                            <components:PrimaryButton ButtonText="{x:Static strings:AppResources.New_decision}"
                                                      Clicked="CreateDecisionClicked"
                                                      HorizontalOptions="Center"
                                                      Margin="0,0,0,5" />

                        </VerticalStackLayout>
                    </Border>

                </Grid>

            </Grid>

        </Grid>

        <!-- BOTTOM NAVBAR -->
        <components:NavigationBar x:Name="NavigationBar"
                                  Grid.Row="1" />

    </Grid>

</ContentPage>