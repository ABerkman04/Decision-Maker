<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Decision_Maker.AHP.AHPComparisonPage"
             xmlns:components="clr-namespace:Decision_Maker.Components"
             BackgroundColor="Grey"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="*,80">

        <ScrollView Grid.Row="0">

            <VerticalStackLayout Padding="30" Spacing="25">

                <!-- Question number -->
                <Label x:Name="QuestionLabel"
                       Text="Question 1"
                       FontSize="26"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>

                <!-- Question -->
                <Label HorizontalOptions="Center"
                        FontSize="18">

                    <Label.FormattedText>
                        <FormattedString>

                            <Span Text="Regarding "/>

                            <Span x:Name="CriterionLabel"
                            FontAttributes="Bold"/>

                            <Span Text=", which is more important: "/>

                            <Span x:Name="OptionALabel"/>

                            <Span Text=" or "/>

                            <Span x:Name="OptionBLabel"/>

                            <Span Text="?"/>

                        </FormattedString>
                    </Label.FormattedText>

                </Label>


                <!-- Option buttons -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="20">

                    <Button x:Name="OptionAButton"
                            CornerRadius="20"
                            HeightRequest="55"
                            BackgroundColor="#CFCFCF"
                            Clicked="OptionAClicked"/>

                    <Button x:Name="OptionBButton"
                            Grid.Column="1"
                            CornerRadius="20"
                            HeightRequest="55"
                            BackgroundColor="#CFCFCF"
                            Clicked="OptionBClicked"/>

                </Grid>


                <Label Text="Select how important it is compared to the other option:"
                       FontSize="16"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>


                <Grid ColumnDefinitions="*,*,*,*,*,*,*,*,*">

                    <Label Text="1" HorizontalOptions="Center"/>
                    <Label Text="2" Grid.Column="1" HorizontalOptions="Center"/>
                    <Label Text="3" Grid.Column="2" HorizontalOptions="Center"/>
                    <Label Text="4" Grid.Column="3" HorizontalOptions="Center"/>
                    <Label Text="5" Grid.Column="4" HorizontalOptions="Center"/>
                    <Label Text="6" Grid.Column="5" HorizontalOptions="Center"/>
                    <Label Text="7" Grid.Column="6" HorizontalOptions="Center"/>
                    <Label Text="8" Grid.Column="7" HorizontalOptions="Center"/>
                    <Label Text="9" Grid.Column="8" HorizontalOptions="Center"/>

                </Grid>


                <Slider Minimum="1"
                        Maximum="9"
                        Value="5"
                        ValueChanged="SliderChanged"/>


                <Grid ColumnDefinitions="*,*">

                    <Label Text="Equally important"
                           FontSize="14"/>

                    <Label Text="Extremely more important"
                           Grid.Column="1"
                           FontSize="14"
                           HorizontalOptions="End"/>

                </Grid>


                <Frame Padding="20"
                       BackgroundColor="#E5E5E5"
                       CornerRadius="20"
                       HasShadow="True">

                    <VerticalStackLayout Spacing="10">

                        <Label Text="Summary"
                               FontAttributes="Bold"
                               FontSize="18"/>

                        <Label x:Name="ChoiceLabel"
                               Text="Your Choice: -"/>

                        <Label x:Name="StrengthLabel"
                               Text="Strength: 5 - Strongly more important"/>

                    </VerticalStackLayout>

                </Frame>


                <Grid ColumnDefinitions="*,*" ColumnSpacing="20">

                    <Button Text="Back"
                            CornerRadius="25"
                            HeightRequest="55"
                            BackgroundColor="#CFCFCF"
                            Clicked="BackClicked"/>

                    <Button Text="Continue"
                            Grid.Column="1"
                            CornerRadius="25"
                            HeightRequest="55"
                            BackgroundColor="#CFCFCF"
                            Clicked="ContinueClicked"/>

                </Grid>

            </VerticalStackLayout>

        </ScrollView>

        <components:NavigationBar Grid.Row="1"/>

    </Grid>

</ContentPage>