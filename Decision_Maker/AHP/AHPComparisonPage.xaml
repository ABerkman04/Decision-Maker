<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Decision_Maker.AHP.AHPComparisonPage"
             xmlns:components="clr-namespace:Decision_Maker.Components"
             xmlns:strings="clr-namespace:Decision_Maker.Resources.Localization"
             BackgroundColor="Grey"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="*,80"
          RowSpacing="0">

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="0">

            <!-- background -->
            <Border BackgroundColor="#C4F1C0"
                    StrokeThickness="0" />

            <!-- pattern -->
            <Image Source="pattern.png"
                   Aspect="AspectFill" />

            <ScrollView>
                <Grid Padding="20,30,20,20"
                      RowDefinitions="Auto,*">

                    <!-- HEADER -->
                    <HorizontalStackLayout Grid.Row="0"
                                           Spacing="12">

                        <Image Source="icon1.png"
                               WidthRequest="34"
                               HeightRequest="34"
                               Aspect="AspectFit" />

                        <Label Text="{x:Static strings:AppResources.Decision_Maker}"
                               FontSize="20"
                               FontFamily="AlegreyaSansExtraBold"
                               VerticalOptions="Center"
                               TextColor="Black" />
                    </HorizontalStackLayout>

                    <!-- CONTENT -->
                    <VerticalStackLayout Grid.Row="1"
                                         Spacing="20"
                                         Margin="0,40,0,20">

                        <!-- QUESTION CARD -->
                        <Border BackgroundColor="#FFFFFF"
                                Stroke="#D9D9D9"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 16"
                                Padding="20,22">

                            <Border.Shadow>
                                <Shadow Brush="#000000"
                                        Offset="0,1"
                                        Radius="4"
                                        Opacity="0.40" />
                            </Border.Shadow>

                            <VerticalStackLayout Spacing="16">

                                <!-- Question title -->
                                <Label x:Name="QuestionLabel"
                                       Text="{x:Static strings:AppResources.Question}"
                                       FontSize="20"
                                       FontFamily="AlegreyaSansExtraBold"
                                       HorizontalTextAlignment="Center"
                                       TextColor="Black" />

                                <!-- Question sentence -->
                                <Label HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       FontSize="16"
                                       FontFamily="AlegreyaSansRegular"
                                       TextColor="Black"
                                       LineBreakMode="WordWrap">

                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{x:Static strings:AppResources.Regarding}" />
                                            <Span x:Name="CriterionLabel"
                                                  FontAttributes="Bold" />
                                            <Span Text="{x:Static strings:AppResources.which_is_more_important}"/>
                                            <Span x:Name="OptionALabel" />
                                            <Span Text="{x:Static strings:AppResources.or}" />
                                            <Span x:Name="OptionBLabel" />
                                            <Span Text="?" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>

                                <!-- Option buttons -->
                                <Grid ColumnDefinitions="*,*"
                                      ColumnSpacing="12">

                                    <Button x:Name="OptionAButton"
                                            CornerRadius="16"
                                            HeightRequest="46"
                                            BackgroundColor="#F6F6F6"
                                            BorderColor="#C4F1C0"
                                            BorderWidth="1"
                                            TextColor="Black"
                                            FontSize="16"
                                            FontFamily="AlegreyaSansRegular"
                                            Clicked="OptionAClicked" />

                                    <Button x:Name="OptionBButton"
                                            Grid.Column="1"
                                            CornerRadius="16"
                                            HeightRequest="46"
                                            BackgroundColor="#F6F6F6"
                                            BorderColor="#C4F1C0"
                                            BorderWidth="1"
                                            TextColor="Black"
                                            FontSize="16"
                                            FontFamily="AlegreyaSansRegular"
                                            Clicked="OptionBClicked" />

                                </Grid>

                                <!-- Helper text -->
                                <Label Text="{x:Static strings:AppResources.Select_how_important_it_is_compared_to_the_other_option}"
                                       FontSize="15"
                                       FontFamily="AlegreyaSansRegular"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       TextColor="Black" />

                                <!-- Scale numbers -->
                                <Grid ColumnDefinitions="*,*,*,*,*,*,*,*,*"
                                      Margin="4,0,4,0">

                                    <Label Text="1" HorizontalOptions="Center" FontSize="14" TextColor="Black" />
                                    <Label Text="2" Grid.Column="1" HorizontalOptions="Center" FontSize="14" TextColor="Black" />
                                    <Label Text="3" Grid.Column="2" HorizontalOptions="Center" FontSize="14" TextColor="Black" />
                                    <Label Text="4" Grid.Column="3" HorizontalOptions="Center" FontSize="14" TextColor="Black" />
                                    <Label Text="5" Grid.Column="4" HorizontalOptions="Center" FontSize="14" TextColor="Black" />
                                    <Label Text="6" Grid.Column="5" HorizontalOptions="Center" FontSize="14" TextColor="Black" />
                                    <Label Text="7" Grid.Column="6" HorizontalOptions="Center" FontSize="14" TextColor="Black" />
                                    <Label Text="8" Grid.Column="7" HorizontalOptions="Center" FontSize="14" TextColor="Black" />
                                    <Label Text="9" Grid.Column="8" HorizontalOptions="Center" FontSize="14" TextColor="Black" />

                                </Grid>

                                <!-- Slider -->
                                <Slider x:Name="ImportanceSlider"
                                        Minimum="1"
                                        Maximum="9"
                                        Value="1"
                                        MinimumTrackColor="Black"
                                        MaximumTrackColor="Black"
                                        ThumbColor="Lightgrey"
                                        ValueChanged="SliderChanged" />

                                <!-- Scale meaning -->
                                <Grid ColumnDefinitions="*,*"
                                      Margin="0,-20,0,0">

                                    <Label Text="{x:Static strings:AppResources.Equally_important}"
                                           FontSize="12"
                                           FontFamily="AlegreyaSansRegular"
                                           TextColor="Black"
                                           LineBreakMode="WordWrap" />

                                    <Label Text="{x:Static strings:AppResources.Extremely_more_important}"
                                           Grid.Column="1"
                                           FontSize="12"
                                           FontFamily="AlegreyaSansRegular"
                                           TextColor="Black"
                                           HorizontalTextAlignment="End"
                                           HorizontalOptions="End"
                                           LineBreakMode="WordWrap" />

                                </Grid>

                            </VerticalStackLayout>
                        </Border>

                        <!-- SUMMARY CARD -->
                        <Border BackgroundColor="#FFFFFF"
                                Stroke="#D9D9D9"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 16"
                                Padding="20,22">

                            <Border.Shadow>
                                <Shadow Brush="#000000"
                                        Offset="0,1"
                                        Radius="4"
                                        Opacity="0.40" />
                            </Border.Shadow>

                            <VerticalStackLayout Spacing="12">

                                <Label Text="{x:Static strings:AppResources.Summary}"
                                       FontSize="20"
                                       FontFamily="AlegreyaSansExtraBold"
                                       HorizontalTextAlignment="Center"
                                       TextColor="Black" />

                                <Label x:Name="ChoiceLabel"
                                       Text="{x:Static strings:AppResources.Your_choice}"
                                       FontSize="16"
                                       FontFamily="AlegreyaSansRegular"
                                       TextColor="Black" />

                                <Label x:Name="StrengthLabel"
                                       Text="{x:Static strings:AppResources.Strength_1}"
                                       FontSize="16"
                                       FontFamily="AlegreyaSansRegular"
                                       TextColor="Black"
                                       LineBreakMode="WordWrap" />

                                <components:PrimaryButton x:Name="ContinueButton"
                              ButtonText="{x:Static strings:AppResources.Continue}"
                              Clicked="ContinueClicked"
                              HorizontalOptions="Center"
                              Margin="0,4,0,3"
                              IsEnabled="False"
                              Opacity="0.5" />

                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>
                </Grid>
            </ScrollView>

        </Grid>

        <!-- BOTTOM NAVBAR -->
        <components:NavigationBar Grid.Row="1" />

    </Grid>
</ContentPage>