<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Decision_Maker"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="*,Auto,*,Auto"
          Padding="30">

        <!-- Ülemine sisu -->
        <VerticalStackLayout Grid.Row="0"
                             Spacing="10"
                             HorizontalOptions="Center"
                             VerticalOptions="Center">

            <!-- Logo placeholder -->
            <Frame HeightRequest="120"
                   WidthRequest="120"
                   CornerRadius="25"
                   BackgroundColor="#D9D9D9"
                   HasShadow="False"
                   HorizontalOptions="Center"/>

            <!-- Pealkiri -->
            <Label Text="Valiku Võlur"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="Black"
                   HorizontalOptions="Center"/>

            <!-- Alapealkiri -->
            <Label Text="Põhjendatud otsus, rahulikum meel!"
                   FontSize="14"
                   TextColor="Gray"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>


        <!-- Spacer -->
        <BoxView Grid.Row="2"/>

        <!-- Alumine nupp -->
        <Button Text="Alusta"
            Clicked="OnStartClicked"
            HeightRequest="55"
            WidthRequest="200"
            CornerRadius="27"
            BackgroundColor="#D9D9D9"
            TextColor="Black"
            HorizontalOptions="Center"
            Margin="0,0,0,40"/>

    </Grid>

</ContentPage>