<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Decision_Maker.MainPage"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="*,Auto,Auto, Auto, Auto, Auto, Auto"
          Padding="30">

        <!-- Ülemine sisu -->
        <VerticalStackLayout Grid.Row="0"
                             Spacing="10"
                             HorizontalOptions="Center"
                             VerticalOptions="Center">

            <Frame HeightRequest="120"
                   WidthRequest="120"
                   CornerRadius="25"
                   BackgroundColor="#D9D9D9"
                   HasShadow="False"
                   HorizontalOptions="Center"/>

            <Label Text="Decision Maker"
                   FontSize="36"
                   FontAttributes="Bold"
                   TextColor="Black"
                   HorizontalOptions="Center"/>

            <Label Text="Well-founded decision, calmer mind"
                   FontSize="14"
                   TextColor="Gray"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>



        <Button Grid.Row="3"
                Text="Log in"
                Clicked="OnLoginClicked"
                HeightRequest="55"
                WidthRequest="200"
                CornerRadius="27"
                BackgroundColor="#D9D9D9"
                TextColor="Black"
                HorizontalOptions="Center"
                Margin="0,0,0,40"/>

        <Button Grid.Row="4"
                Text="Create an account"
                Clicked="OnSignUpPageClicked"
                HeightRequest="55"
                WidthRequest="200"
                CornerRadius="27"
                BackgroundColor="#D9D9D9"
                TextColor="Black"
                HorizontalOptions="Center"
                Margin="0,0,0,40"/>

        <Button Grid.Row="5"
                Text="Start as guest"
                Clicked="OnGuestClicked"
                HeightRequest="55"
                WidthRequest="200"
                CornerRadius="27"
                BackgroundColor="#D9D9D9"
                TextColor="Black"
                HorizontalOptions="Center"
                Margin="0,0,0,40"/>

        <Button Grid.Row="6"
                Text="Test environment"
                Clicked="OnTestEnvironmentClicked"
                HeightRequest="10"
                WidthRequest="75"
                CornerRadius="27"
                BackgroundColor="#D9D9D9"
                TextColor="Black"
                HorizontalOptions="Center"
                Margin="0,0,0,40"/>

    </Grid>

</ContentPage>
    