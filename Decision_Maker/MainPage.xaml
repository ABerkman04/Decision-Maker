<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:Decision_Maker.Components"
             xmlns:strings="clr-namespace:Decision_Maker.Resources.Localization"
             x:Class="Decision_Maker.MainPage"
             BackgroundColor="Gray"
             NavigationPage.HasNavigationBar="False">

    <Grid Padding="0">
        <Grid RowDefinitions="2.35*,1*">

            <!-- Top section -->
            <Border Grid.Row="0"
                    BackgroundColor="#C4F1C0"
                    HeightRequest="780"
                    StrokeThickness="0"
                    Padding="0">

                <Grid>
                    <!-- Background pattern image -->
                    <Image Source="pattern.png"
                           Aspect="AspectFill" />

                    <VerticalStackLayout HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Spacing="0">

                        <!-- Logo -->
                        <Image Source="icon1.png"
                               HeightRequest="120"
                               WidthRequest="120"
                               Aspect="AspectFit"
                               HorizontalOptions="Center" />

                        <Label Text="{x:Static strings:AppResources.Decision_Maker}"
                               FontSize="42"
                               FontFamily="AlegreyaSansExtraBold"
                               TextColor="Black"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               Margin="0,8,0,0" />

                        <Label Text="{x:Static strings:AppResources.Well_founded_decision}"
                               FontSize="16"
                               FontFamily="AlegreyaSansRegular"
                               TextColor="Black"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Bottom card -->
            <Border Grid.Row="1"
                    HeightRequest="280"
                    BackgroundColor="#FFFFFF"
                    Stroke="#D4D2D2"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 30,30,0,0"
                    Padding="0,50,0,0"
                    TranslationY="0">

                <Border.Shadow>
                    <Shadow
                        Brush="#000000"
                        Offset="0,1"
                        Radius="4"
                        Opacity="0.40" />
                </Border.Shadow>

                <VerticalStackLayout HorizontalOptions="Fill"
                                     Spacing="18">

                    <components:PrimaryButton ButtonText="{x:Static strings:AppResources.Log_in}"
                                              Clicked="OnLoginClicked"
                                              HorizontalOptions="Center"
                                              Margin="0,6,0,0" />

                    <components:SecondaryButton ButtonText="{x:Static strings:AppResources.Start_as_guest}"
                                                Clicked="OnGuestClicked"
                                                HorizontalOptions="Center" />

                    <HorizontalStackLayout HorizontalOptions="Center"
                                           Spacing="0"
                                           Margin="0,4,0,0">

                        <Label Text="{x:Static strings:AppResources.Dont_have_an_account}"
                               FontSize="14"
                               FontFamily="AlegreyaSansRegular"
                               TextColor="Black"
                               VerticalTextAlignment="Center" />

                        <Label Text="{x:Static strings:AppResources.Register}"
                               FontSize="14"
                               FontFamily="AlegreyaSansRegular"
                               TextColor="Black"
                               TextDecorations="Underline"
                               VerticalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSignUpPageClicked" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                    <!-- Keelevalik -->
                    <HorizontalStackLayout HorizontalOptions="Center"
                                           Spacing="4"
                                           Margin="0,-6,0,0">

                        <Image Source="globe.png"
                               HeightRequest="16"
                               WidthRequest="16"
                               VerticalOptions="Center"
                               Margin="0,0,2,0" />

                        <Label x:Name="EstonianLabel"
                               Text="Eesti"
                               FontSize="14"
                               FontFamily="AlegreyaSansRegular"
                               TextColor="Black"
                               VerticalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="EstonianClicked" />
                            </Label.GestureRecognizers>
                        </Label>

                        <Label Text="|"
                               FontSize="13"
                               FontFamily="AlegreyaSansRegular"
                               TextColor="#4A4A4A"
                               VerticalTextAlignment="Center" />

                        <Label x:Name="EnglishLabel"
                               Text="English"
                               FontSize="14"
                               FontFamily="AlegreyaSansRegular"
                               TextColor="Black"
                               VerticalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="EnglishClicked" />
                            </Label.GestureRecognizers>
                        </Label>

                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>

        </Grid>
    </Grid>

</ContentPage>