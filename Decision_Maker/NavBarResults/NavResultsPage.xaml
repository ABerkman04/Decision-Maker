<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Decision_Maker.NavBarResults.NavResultsPage"
             xmlns:components="clr-namespace:Decision_Maker.Components"
             Title="NavResultsPage"
             BackgroundColor="Grey"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="*,80"
          RowSpacing="0">

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="0">

            <!-- background -->
            <Border BackgroundColor="#C4F1C0"
                    StrokeThickness="0" />

            <!-- pattern -->
            <Image Source="pattern.png"
                   Aspect="AspectFill" />

            <!-- content layout -->
            <Grid Padding="20,30,20,20"
                  RowDefinitions="Auto,*">

                <!-- HEADER -->
                <HorizontalStackLayout Grid.Row="0"
                                       Spacing="12">

                    <Image Source="icon1.png"
                           WidthRequest="34"
                           HeightRequest="34"
                           Aspect="AspectFit" />

                    <Label Text="Decision Maker"
                           FontSize="20"
                           FontFamily="AlegreyaSansExtraBold"
                           VerticalOptions="Center"
                           TextColor="Black" />
                </HorizontalStackLayout>

                <!-- CENTER AREA -->
                <Grid Grid.Row="1">

                    <Border BackgroundColor="#FFFFFF"
                            Stroke="#D9D9D9"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16"
                            Padding="20,22"
                            HorizontalOptions="Fill"
                            VerticalOptions="Center"
                            Margin="0,-80,0,0">

                        <Border.Shadow>
                            <Shadow Brush="#000000"
                                    Offset="0,1"
                                    Radius="4"
                                    Opacity="0.40" />
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="16">

                            <!-- back + title row -->
                            <Grid ColumnDefinitions="30,*,30"
                                  VerticalOptions="Center">

                                <Image Grid.Column="0"
                                       Source="tagasi.png"
                                       WidthRequest="22"
                                       HeightRequest="22"
                                       HorizontalOptions="Start"
                                       VerticalOptions="Center"
                                       Aspect="AspectFit">
                                    <!-- NUPU JAOKS-->
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="BackClicked" />
                                    </Image.GestureRecognizers>
                                </Image>

                                <Label Grid.Column="1"
                                       Text="Results"
                                       FontSize="20"
                                       FontFamily="AlegreyaSansExtraBold"
                                       HorizontalTextAlignment="Center"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       TextColor="Black" />

                                <BoxView Grid.Column="2"
                                         Opacity="0" />
                            </Grid>

                            <Label x:Name="DecisionNameLabel"
                                   FontSize="16"
                                   FontFamily="AlegreyaSansRegular"
                                   HorizontalTextAlignment="Center"
                                   TextColor="Black" />

                            <CollectionView x:Name="ResultsList"
                                            Margin="0,10,0,0"
                                            SelectionMode="None">

                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,14"
                                                Padding="25,12"
                                                BackgroundColor="#F6F6F6"
                                                Stroke="#A8DAB0"
                                                StrokeThickness="1">

                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="16" />
                                            </Border.StrokeShape>

                                            <Grid ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="12">

                                                <Label Grid.Column="0"
                                                       Text="{Binding OptionName}"
                                                       FontSize="16"
                                                       FontFamily="AlegreyaSansRegular"
                                                       TextColor="Black"
                                                       VerticalOptions="Center" />

                                                <Label Grid.Column="1"
                                                       Text="{Binding Score}"
                                                       FontSize="16"
                                                       FontFamily="AlegreyaSansExtraBold"
                                                       TextColor="Black"
                                                       VerticalOptions="Center"
                                                       HorizontalOptions="End" />

                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>

                            </CollectionView>

                        </VerticalStackLayout>
                    </Border>

                </Grid>

            </Grid>

        </Grid>

        <!-- BOTTOM NAVBAR -->
        <components:NavigationBar x:Name="NavigationBar"
                                  Grid.Row="1" />

    </Grid>
</ContentPage>