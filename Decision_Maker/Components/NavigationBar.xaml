<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:strings="clr-namespace:Decision_Maker.Resources.Localization"
             x:Class="Decision_Maker.Components.NavigationBar">


    <Grid BackgroundColor= "WhiteSmoke"
          ColumnDefinitions="*,*,*"
          Padding="10, 20"
          VerticalOptions="End">

        <!-- HOME -->
        <VerticalStackLayout Grid.Column="0"
                             HorizontalOptions="Center"
                             Spacing="3">

            <Image Source="home1.png"
                   WidthRequest="22"/>

            <Label Text="{x:Static strings:AppResources.Home}"
                   FontSize="14"
                   HorizontalOptions="Center"
                   FontFamily="AlegreyaSansRegular" />

            <!-- active line -->
            <BoxView x:Name="HomeLine"
                     Margin="-3"
                     HeightRequest="1"
                     WidthRequest="40"
                     BackgroundColor="Grey"
                     IsVisible="False"/>

            <VerticalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Tapped="GoHome"/>
            </VerticalStackLayout.GestureRecognizers>

        </VerticalStackLayout>


        <!-- RESULTS -->
        <VerticalStackLayout Grid.Column="1"
                             HorizontalOptions="Center"
                             Spacing="3">

            <Image Source="results1.png"
                   WidthRequest="22"/>

            <Label Text="{x:Static strings:AppResources.Results}"
                   FontSize="14"
                   HorizontalOptions="Center"
                   FontFamily="AlegreyaSansRegular"/>

            <BoxView x:Name="ResultsLine"
                     Margin="-3"
                     HeightRequest="1"
                     WidthRequest="40"
                     BackgroundColor="Grey"
                     IsVisible="False"/>

            <VerticalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Tapped="GoResults"/>
            </VerticalStackLayout.GestureRecognizers>

        </VerticalStackLayout>


        <!-- SETTINGS -->
        <VerticalStackLayout Grid.Column="2"
                             HorizontalOptions="Center"
                             Spacing="3">

            <Image Source="settings1.png"
                   WidthRequest="22"/>

            <Label Text="{x:Static strings:AppResources.Settings}"
                   FontSize="14"
                   HorizontalOptions="Center"
                   FontFamily="AlegreyaSansRegular" />

            <BoxView x:Name="SettingsLine"
                     Margin="-3"
                     HeightRequest="1"
                     WidthRequest="40"
                     BackgroundColor="Grey"
                     IsVisible="False"/>

            <VerticalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Tapped="GoSettings"/>
            </VerticalStackLayout.GestureRecognizers>

        </VerticalStackLayout>

    </Grid>

</ContentView>