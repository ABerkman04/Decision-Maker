<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Decision_Maker.Components.PrimaryButton"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="ThisButton">

    <Border
        WidthRequest="320"
        BackgroundColor="#C4F1C0"
        Stroke="#D4D2D2"
        StrokeThickness="1"
        StrokeShape="RoundRectangle 16">

        <Border.Shadow>
            <Shadow
                Brush="#000000"
                Offset="0,2"
                Radius="4"
                Opacity="0.14" />
        </Border.Shadow>

        <Button
            Text="{Binding ButtonText, Source={x:Reference ThisButton}}"
            BackgroundColor="Transparent"
            TextColor="#222222"
            FontSize="18"
            FontFamily="AlegreyaSansBold"
            HeightRequest="48"
            CornerRadius="16"
            BorderWidth="0"
            Padding="0"
            Clicked="InnerButton_Clicked" />
    </Border>
</ContentView>