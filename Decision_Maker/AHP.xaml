<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Decision_Maker.AHP"
             BackgroundColor="White">

    <VerticalStackLayout Padding="30"
                         Spacing="25"
                         VerticalOptions="Center">

        <!-- Title -->
        <Label Text="Lorem ipsum"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <Label Text="Lorem ipsum dolor sit amet, consectetur adipiscing elit."
               FontSize="14"
               HorizontalTextAlignment="Center"
               TextColor="Gray" />

        <!-- Alternatives -->
        <VerticalStackLayout Spacing="10">
            <Label Text="Alternatives"
                   FontAttributes="Bold" />

            <HorizontalStackLayout Spacing="15"
                                   VerticalOptions="Center">

                <Button Text="-" Clicked="OnAlternativesMinus"/>
                <Label Text="{Binding Alternatives}"
                       FontSize="18"
                       VerticalOptions="Center"/>
                <Button Text="+" Clicked="OnAlternativesPlus"/>

            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- Criteria -->
        <VerticalStackLayout Spacing="10">
            <Label Text="Criteria"
                   FontAttributes="Bold" />

            <HorizontalStackLayout Spacing="15"
                                   VerticalOptions="Center">

                <Button Text="-" Clicked="OnCriteriaMinus"/>
                <Label Text="{Binding Criteria}"
                       FontSize="18"
                       VerticalOptions="Center"/>
                <Button Text="+" Clicked="OnCriteriaPlus"/>

            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- Buttons -->
        <HorizontalStackLayout Spacing="20"
                               HorizontalOptions="Center">

            <Button Text="Back"
                    Clicked="OnBackClicked"/>

            <Button Text="Continue"
                    Clicked="OnContinueClicked"/>

        </HorizontalStackLayout>

    </VerticalStackLayout>
</ContentPage>