<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Decision_Maker.Login.SignUpPage"
             Title="SignUpPage"
            BackgroundColor="#1E1E1E">
    <Grid>
        <Frame
            HasShadow="False"
            BackgroundColor="#F2F2F2"
            VerticalOptions="Center">

            <ScrollView>
                <VerticalStackLayout Spacing="15" Padding="25">

                    <!-- Ülemine lainejoon -->
                    <Frame HeightRequest="120"
                   WidthRequest="120"
                   CornerRadius="25"
                   BackgroundColor="#D9D9D9"
                   HasShadow="False"
                   HorizontalOptions="Center"/>

                    <!-- Pealkiri -->
                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                        <Label
                            Text="Register"
                            FontSize="26"
                            FontAttributes="Bold"
                            TextColor="Black"
                            HorizontalOptions="Center" />
                        <BoxView
                            HeightRequest="2"
                            WidthRequest="60"
                            BackgroundColor="Black"
                            HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- Display Name -->
                    <Entry x:Name="DisplayNameEntry"
                       Placeholder="Enter display name"
                       BackgroundColor="Transparent"
                       Margin="15,0"/>

                    <!-- Email -->
                    <Entry x:Name="EmailEntry"
                       Placeholder="Enter email"
                       Keyboard="Email"
                       BackgroundColor="Transparent"
                       Margin="15,0"/>

                    <!-- Password -->
                    <Entry x:Name="PasswordEntry"
                       Placeholder="Enter password"
                       IsPassword="True"
                       BackgroundColor="Transparent"
                       Margin="15,0"/>

                    <!-- Repeat Password -->
                    <Entry x:Name="RepeatPasswordEntry"
                       Placeholder="Repeat password"
                       IsPassword="True"
                       BackgroundColor="Transparent"
                       Margin="15,0"/>

                    <!-- Sign up -->
                    <Button Text="Sign up"
                    Clicked="OnSignUpClicked"
                    BackgroundColor="#D6D6D6"
                    TextColor="#0064e0"
                    CornerRadius="20"
                    HeightRequest="45"
                    Margin="0,10,0,20"/>

                    <!-- Already have account -->
                    <Button Text="Already have an account? Sign in"
                    Clicked="OnSignInClicked"
                    BackgroundColor="#0064e0"
                    TextColor="#D6D6D6"
                    CornerRadius="20"
                    HeightRequest="45"
                    Margin="0,-10,0,20"/>
                </VerticalStackLayout>
            </ScrollView>
        </Frame>
    </Grid>
</ContentPage>